{
  "name": "opencode-task-hub",
  "version": "1.0.0",
  "description": "🚀 Real-time task hub for managing multiple OpenCode AI coding assistant sessions with WebSocket dashboard",
  "type": "module",
  "main": "server.js",
  "bin": {
    "opencode-task-hub": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:win": "node --watch server.js",
    "postinstall": "node scripts/postinstall.js",
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.js",
    "lint": "node scripts/lint.js",
    "lint:fix": "node scripts/lint.js --fix",
    "prepare": "husky install"
  },
  "keywords": [
    "opencode",
    "opencode-ai",
    "task-management",
    "task-hub",
    "multi-agent",
    "multi-agent-task",
    "ai-coding",
    "ai-assistant",
    "developer-tools",
    "devtools",
    "websocket",
    "websocket-dashboard",
    "real-time",
    "real-time-updates",
    "session-manager",
    "session-tracking",
    "project-management",
    "productivity",
    "code-assistant"
  ],
  "author": "lztry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lztry/opencode-task-hub"
  },
  "bugs": {
    "url": "https://github.com/lztry/opencode-task-hub/issues"
  },
  "homepage": "https://github.com/lztry/opencode-task-hub#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "husky": "^9.0.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/lztry"
  }
}
